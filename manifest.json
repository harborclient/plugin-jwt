{
  "id": "com.harborclient.plugins.jwt",
  "name": "JWT Inspector",
  "author": "HarborClient",
  "version": "1.0.8",
  "description": "README.md",
  "summary": "Scans response headers and body for JWT-shaped strings and decodes the selected token.",
  "categories": [
    "jwt",
    "response"
  ],
  "screenshots": [
    "https://raw.githubusercontent.com/harborclient/plugin-jwt/main/screenshot.png"
  ],
  "engines": {
    "harborclient": ">=1.9.0"
  },
  "renderer": "dist/renderer.js",
  "permissions": [
    "ui"
  ],
  "contributes": {
    "responseTabs": [
      {
        "id": "jwt",
        "title": "JWT"
      }
    ]
  }
}
